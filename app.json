{
  "expo": {
    "name": "bharatbhavanapp",
    "slug": "bharatbhavanapp",
    "version": "1.0.0",
    "newArchEnabled": true,
    "scheme": "bharatbhavanapp",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-dev-launcher",
        {
          "launchMode": "most-recent"
        }
      ],
      "react-native-edge-to-edge",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.bharatbhavanapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.anonymous.bharatbhavanapp"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "49e23ef8-34d4-476c-9db0-8da933a408c3"
      }
    },
    "owner": "khetwaldevesh"
  }
}